# Overwritten when you run default `npm start` / `dev` (see scripts/start-dev-tunnel.cjs):
# localtunnel URL to ability-api + EXPO_LOCK_API_URL=1. Port comes from ability-api/.env `PORT`
# (fallback API_PORT env or 3002).
#
# For LAN-only dev: use `npm run start:lan` — sync script sets EXPO_PUBLIC_API_URL to your PC LAN IP.
# Manual override: set EXPO_PUBLIC_API_URL and EXPO_LOCK_API_URL=1 if you use another tunnel.

EXPO_PUBLIC_API_URL=http://127.0.0.1:3002
