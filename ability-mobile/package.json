{
  "name": "ability-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "expo": "expo",
    "sync-api-url": "node scripts/sync-expo-api-url.cjs",
    "start": "node scripts/start-dev-tunnel.cjs",
    "dev": "node scripts/start-dev-tunnel.cjs",
    "start:lan": "node scripts/sync-expo-api-url.cjs && npm exec -- expo start --lan",
    "start:tunnel": "node scripts/start-dev-tunnel.cjs",
    "start:ios-safe": "node scripts/start-ios-safe.cjs",
    "start:metro-only": "node scripts/sync-expo-api-url.cjs && npm exec -- expo start --tunnel",
    "start:clear": "node scripts/start-dev-tunnel.cjs --clear",
    "start:clear:lan": "node scripts/sync-expo-api-url.cjs && npm exec -- expo start -c --lan",
    "build:web": "npm exec -- expo export --platform web",
    "lint": "npm exec -- expo lint",
    "typecheck": "tsc --noEmit",
    "android": "npm exec -- expo run:android",
    "ios": "npm exec -- expo run:ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@lucide/lab": "^0.1.2",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "bcryptjs": "^3.0.3",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.7",
    "expo-camera": "~17.0.8",
    "expo-constants": "~18.0.9",
    "expo-contacts": "~15.0.7",
    "expo-crypto": "~15.0.8",
    "expo-font": "~14.0.8",
    "expo-haptics": "~15.0.7",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~8.0.8",
    "expo-local-authentication": "^55.0.13",
    "expo-random": "^14.0.1",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.7",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.7",
    "expo-web-browser": "~15.0.7",
    "lucide-react-native": "^0.544.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "~19.1.10",
    "@types/react-native": "^0.72.8",
    "localtunnel": "^2.0.2",
    "typescript": "~5.9.2"
  }
}
